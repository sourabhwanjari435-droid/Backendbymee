<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-100">
         <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input class="block px-10 py-4 w-full rounded-md bg-zinc-700" type="text" placeholder="Title goes here" name="title">
                <textarea class="block mt-4 px-20 py-4 w-full rounded-md bg-zinc-600 " placeholder="Write your task details" name="details"></textarea>
                <input class="block mt-4 py-4 bg-zinc-900 rounded-md" type="submit" value="Create Task">
            </form>        
         </div>

         <div class="tasks flex gap-4 flex-wrap p-10">
            <% if(files.length > 0){ %>
                <% files.forEach(function(val){ %>
            <div class="task w-72 h-40 px-10 py-4 rounded-md justify-between  bg-zinc-800">
                <h1 class="text-white tracking-tighter"><%= val %></h1>
                <div class="flex w-full  items-center inline-block mt-3">
                <a class="text-blue-500  " href="/file/<%= val %>">read more.</a>
                <a class="text-zinc-400 "href="/edit/<%= val %>">Edit filename</a>
            </div>
                </div>
            
            <% }) %>
          <% } else { %>
              <h3 class="text-zinc-600">No task yet.</h3>
          <% } %>      
        </div>
    </div> 
    
    
</body>
</html>