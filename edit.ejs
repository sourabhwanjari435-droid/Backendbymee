<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900 p-10 text-white">
        <a class="text-blue-500 inline-block mb-10" href="/">GO Back To Home</a>
            <form action="/edit" method="post">
                <input class="block px-10 py-4 w-1/4 rounded-md bg-zinc-700" type="text" placeholder="" name="previous" value="<%= filename %>">

                <input class="block px-10 py-4 w-1/4 rounded-md bg-zinc-700" type="text" placeholder="New name" name="new">
                
                <input class="mt-2 bg-yellow-600 px-5 py-2 rounded-md" type="submit" value="Updata filename">
            </form>
        
    </div> 
    
    
</body>
</html>